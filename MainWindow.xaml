<Window x:Class="RoLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RO Launcher"
        Width="1100"
        Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Assets/bg.jpg" Stretch="UniformToFill" />
        </Grid.Background>

        <Border Background="#660B1120" />

        <Border Width="440"
                Padding="28"
                Background="#F8FFFFFF"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="RO Launcher"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" />

                <TextBlock Margin="0,8,0,24"
                           Text="Escolha entre preparar o ambiente das contas ou abrir o launcher com as configurações salvas."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}" />

                <Button Content="Configurar contas"
                        Click="OpenSetup_Click" />

                <Button Content="Abrir launcher"
                        Margin="0,0,0,0"
                        Click="OpenLauncher_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

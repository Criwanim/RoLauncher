<Window x:Class="RoLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="RO Launcher"
        Width="800 "
        Height="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid>
        <Image Source="/Assets/bg.jpg" Stretch="UniformToFill" Opacity="0.8"/>
        <Rectangle Fill="#55000000"/>

        <materialDesign:Card Width="420"
                             Padding="28"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="RO Launcher"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Account manager tool"
                           Margin="0,8,0,24"
                           Opacity="0.75"
                           TextAlignment="Center"/>

                <Button Content="Configuration"
                        Height="48"
                        Margin="0,0,0,12"
                        Click="OpenSetup_Click"/>

                <Button Content="Open Account"
                        Height="48"
                        Click="OpenLauncher_Click"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
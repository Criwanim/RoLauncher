<Window x:Class="RoLauncher.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Preparação do ambiente"
        Width="980"
        Height="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Setup de contas"
                   FontSize="26"
                   FontWeight="SemiBold"/>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="16"
                BorderBrush="#33000000"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,8,10,0"
                           Text="Game Install:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Height="34"
                         Text="{Binding GameInstallPath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Margin="10,0,0,0"
                        Height="34"
                        Content="Buscar"
                        Command="{Binding BrowseGameInstallPathCommand}"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,16,10,0"
                           Text="App Data:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,16,0,0"
                         Height="34"
                         Text="{Binding AppDataBasePath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Margin="10,16,0,0"
                        Height="34"
                        Content="Buscar"
                        Command="{Binding BrowseAppDataBasePathCommand}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,16,10,0"
                           Text="XD\\PC:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,16,0,0"
                         Height="34"
                         Text="{Binding AppDataPcPath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="2"
                        Grid.Column="2"
                        Margin="10,16,0,0"
                        Height="34"
                        Content="Buscar"
                        Command="{Binding BrowseAppDataPcPathCommand}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,16,0,0"
                    Orientation="Horizontal">
            <Button Width="150"
                    Height="36"
                    Content="Salvar caminhos"
                    Command="{Binding SavePathsCommand}"/>
            <Button Width="170"
                    Height="36"
                    Margin="12,0,0,0"
                    Content="Nova configuração"
                    Click="NewConfiguration_Click"/>
            <Button Width="150"
                    Height="36"
                    Margin="12,0,0,0"
                    Content="Capturar tokens"
                    Command="{Binding CaptureTokensCommand}"/>
        </StackPanel>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="14"
                BorderBrush="#33000000"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock Text="Progresso"
                           FontWeight="SemiBold"/>
                <ProgressBar Margin="0,10,0,0"
                             Height="18"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"/>
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding ProgressMessage}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Margin="0,16,0,0"
                Padding="14"
                BorderBrush="#33000000"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Contas configuradas"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <DataGrid Grid.Row="1"
                          Margin="0,12,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Slot" Binding="{Binding SlotNumber}" Width="80"/>
                        <DataGridTextColumn Header="Código" Binding="{Binding Code}" Width="140"/>
                        <DataGridTextColumn Header="Alias" Binding="{Binding DisplayName}" Width="180"/>
                        <DataGridTextColumn Header="Executável" Binding="{Binding ExecutablePath}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Margin="0,16,0,0"
                Padding="12"
                Background="#11000000"
                CornerRadius="8">
            <TextBlock Text="{Binding Status}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>

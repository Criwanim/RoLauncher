<Window x:Class="RoLauncher.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:RoLauncher.Models"
        Title="Configuração de Contas"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Preparação do ambiente"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Defina os caminhos, crie a instância da conta e capture os tokens após concluir o login."
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <Border Grid.Row="2"
                Padding="18"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Pasta de instalação do jogo" />
                    <TextBox Grid.Column="1"
                             Margin="12,0"
                             Text="{Binding GameInstallPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Content="Selecionar"
                            Command="{Binding BrowseGameInstallPathCommand}" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="AppData LocalLow (base)" />
                    <TextBox Grid.Column="1"
                             Margin="12,0"
                             Text="{Binding AppDataBasePath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Content="Selecionar"
                            Command="{Binding BrowseAppDataBasePathCommand}" />
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="AppData LocalLow\XD\PC" />
                    <TextBox Grid.Column="1"
                             Margin="12,0"
                             Text="{Binding AppDataPcPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Content="Selecionar"
                            Command="{Binding BrowseAppDataPcPathCommand}" />
                </Grid>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Raiz das instâncias clonadas" />
                    <TextBox Grid.Column="1"
                             Margin="12,0"
                             Text="{Binding InstancesRootPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Content="Selecionar"
                            Command="{Binding BrowseInstancesRootPathCommand}" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Button Content="Salvar caminhos"
                        Command="{Binding SavePathsCommand}" />
                <Button Content="Nova configuração"
                        Command="{Binding NewConfigurationCommand}" />
                <Button Content="Capturar tokens"
                        Command="{Binding CaptureTokensCommand}" />
            </StackPanel>

            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Contas configuradas"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Accounts}"
                             SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:AccountProfile}">
                                <Border Margin="4"
                                        Padding="12"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Code}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding InstanceFolderPath}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding CreatedAt, StringFormat='Criada em: {0:dd/MM/yyyy HH:mm}'}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="6"
                Padding="12"
                Background="#EEF2FF"
                BorderBrush="#C7D2FE"
                BorderThickness="1"
                CornerRadius="10">
            <TextBlock Text="{Binding Status}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>

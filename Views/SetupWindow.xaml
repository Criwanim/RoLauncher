<Window x:Class="RoLauncher.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração de Contas"
        Width="1100"
        Height="700"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#14000000">
        <Border Width="980"
                Padding="24"
                Background="White"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Preparação do Ambiente"
                               FontSize="26"
                               FontWeight="Bold"/>
                    <TextBlock Text="Defina os caminhos, crie a conta e capture o login."
                               Margin="0,6,0,0"
                               Opacity="0.75"/>
                </StackPanel>

                <!-- Campos -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Caminho do jogo -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="40"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding GameInstallPath, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Column="1"
                                Margin="12,0,0,0"
                                Height="40"
                                Content="Selecionar pasta"
                                Command="{Binding BrowseGameInstallPathCommand}" />
                    </Grid>

                    <!-- Caminho dos tokens -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="40"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding RuntimeTokenPath, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Grid.Column="1"
                                Margin="12,0,0,0"
                                Height="40"
                                Content="Selecionar pasta"
                                Command="{Binding BrowseRuntimeTokenPathCommand}" />
                    </Grid>

                    <!-- Botões principais -->
                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal">
                        <Button Width="160"
                                Height="42"
                                Content="Salvar caminhos"
                                Command="{Binding SavePathsCommand}" />

                        <Button Width="180"
                                Height="42"
                                Margin="12,0,0,0"
                                Content="Nova configuração"
                                Command="{Binding NewConfigurationCommand}" />

                        <Button Width="160"
                                Height="42"
                                Margin="12,0,0,0"
                                Content="Capturar tokens"
                                Command="{Binding CaptureTokensCommand}" />
                    </StackPanel>
                </Grid>

                <!-- Lista -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Contas configuradas"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Accounts}"
                             SelectedItem="{Binding SelectedAccount}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Code}"
                                               FontWeight="SemiBold"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding InstanceFolderPath}"
                                               Opacity="0.75"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Status -->
                <Border Grid.Row="6"
                        Padding="12"
                        CornerRadius="8"
                        Background="#F2F2F2">
                    <TextBlock Text="{Binding Status}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
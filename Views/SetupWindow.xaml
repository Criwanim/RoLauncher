<Window x:Class="RoLauncher.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração de Contas"
        Width="800"
        Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/Assets/bg.jpg"
                Stretch="UniformToFill"/>
    </Window.Background>

    <Grid Background="#14000000">

        <Border Width="740"
                Padding="16"
                Background="White"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= CAMPOS DE CAMINHO (TOPO) ================= -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- GAME FOLDER -->
                    <StackPanel Grid.Row="0">

                        <TextBlock Text="Game folder"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,0,0,2"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Text="{Binding GameInstallPath}" />

                            <Button Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Height="28"
                                    Width="40"
                                    Command="{Binding BrowseGameInstallPathCommand}">

                                <!--<Viewbox Stretch="Uniform">-->
                                <Canvas Width="16" Height="20">

                                    <!-- Base -->
                                    <Path Fill="#E0B75C"
                                        Data="M3 7C3 6.44772 3.44772 6 4 6H9L11 8H20C20.5523 8 21 8.44772 21 9V18C21 18.5523 20.5523 19 20 19H4C3.44772 19 3 18.5523 3 18V7Z" HorizontalAlignment="Center" Canvas.Left="-9.565" VerticalAlignment="Top" Canvas.Top="-1.914"/>

                                    <!-- Tampa -->
                                    <Path Fill="#F5D27A"
                                         Data="M3 7C3 6.44772 3.44772 6 4 6H9L11 8H20C20.5523 8 21 8.44772 21 9V10H3V7Z"/>

                                </Canvas>
                                <!--</Viewbox>-->

                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- APPDATA PC -->
                    <StackPanel Grid.Row="2">

                        <TextBlock Text="AppData PC"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Margin="0,0,0,2"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                         Height="26"
                         VerticalContentAlignment="Center"
                         Text="{Binding AppDataPcPath}" />

                            <Button Grid.Column="1"
                        Margin="6,0,0,0"
                        Height="26"
                        FontSize="14"
                        Content="📁"
                        Command="{Binding BrowseAppDataPcPathCommand}" />
                        </Grid>
                    </StackPanel>

                    <!-- BOTÕES PRINCIPAIS (COMPACTOS) -->
                    <StackPanel Grid.Row="4"
                    Orientation="Horizontal">

                        <Button Width="90"
                    Height="26"
                    FontSize="11"
                    Content="Salvar"
                    Command="{Binding SavePathsCommand}" />

                        <Button Width="110"
                    Height="26"
                    Margin="6,0,0,0"
                    FontSize="11"
                    Content="Nova config"
                    Command="{Binding NewConfigurationCommand}" />

                        <Button Width="110"
                    Height="26"
                    Margin="6,0,0,0"
                    FontSize="11"
                    Content="Capturar"
                    Command="{Binding CaptureTokensCommand}" />
                    </StackPanel>

                </Grid>

                <!-- ================= LISTA GRANDE ================= -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                   Text="Contas configuradas"
                   FontSize="14"
                   FontWeight="SemiBold"/>

                    <ListBox Grid.Row="2"
                 ItemsSource="{Binding Accounts}"
                 SelectedItem="{Binding SelectedAccount}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8"
                            Margin="3"
                            CornerRadius="6"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                       Text="{Binding Code}"
                                       FontSize="13"
                                       FontWeight="Bold"/>

                                        <TextBlock Grid.Column="1"
                                       Text="{Binding InstanceFolderPath}"
                                       FontSize="12"
                                       Opacity="0.7"
                                       TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- ================= STATUS ================= -->
                <Border Grid.Row="4"
            Padding="6"
            CornerRadius="6"
            Background="#F2F2F2">

                    <TextBlock Text="{Binding Status}"
                   FontSize="11"/>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
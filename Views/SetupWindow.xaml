<Window x:Class="RoLauncher.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Preparação do ambiente"
        Width="980"
        Height="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

            <Style x:Key="ModernDataGridStyle" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="RowBackground" Value="#00FFFFFF"/>
                <Setter Property="AlternatingRowBackground" Value="#08FFFFFF"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#14000000"/>
                <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="RowHeight" Value="50"/>
            </Style>

            <Style x:Key="ModernDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#F4F6FA"/>
                <Setter Property="Foreground" Value="#22304A"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="BorderBrush" Value="#00000000"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="ModernDataGridCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#0F4F7CFF"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#164F7CFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Setup de contas"
                   FontSize="26"
                   FontWeight="SemiBold"/>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                Padding="16"
                Background="#FCFCFD"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,8,10,0"
                           Text="Game Install:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Height="34"
                         Text="{Binding GameInstallPath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Margin="10,0,0,0"
                        Height="34"
                        Content="Buscar"
                        Command="{Binding BrowseGameInstallPathCommand}"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,16,10,0"
                           Text="App Data:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,16,0,0"
                         Height="34"
                         Text="{Binding AppDataBasePath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Margin="10,16,0,0"
                        Height="34"
                        Content="Buscar"
                        Command="{Binding BrowseAppDataBasePathCommand}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,16,0,16"
                    Orientation="Horizontal">
            <Button Width="150"
                    Height="36"
                    Margin="12,0,0,0"
                    Content="Salvar caminhos"
                    Command="{Binding SavePathsCommand}"/>
            <Button Width="170"
                    Height="36"
                    Margin="12,0,0,0"
                    Content="Nova configuração"
                    Click="NewConfiguration_Click"/>
            <Button Width="150"
                    Height="36"
                    Margin="12,0,0,0"
                    Content="Capturar tokens"
                    Command="{Binding CaptureTokensCommand}"/>
            <Button Width="150"
                    Height="36"
                    Margin="12,0,0,0"
                    Content="Deletar conta"
                    Click="DeleteSelectedAccount_Click"/>
        </StackPanel>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="14"
                Background="#F8FAFD"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="14"
                Visibility="{Binding IsCopyProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Copiando arquivos"
                           FontWeight="SemiBold"
                           FontSize="15"/>
                <ProgressBar Margin="0,10,0,0"
                             Height="18"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"/>
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding ProgressMessage}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="4"
                Margin="0,16,0,0"
                Padding="16"
                Background="#FCFCFD"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock Text="Contas configuradas"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Border DockPanel.Dock="Right"
                            Padding="10,4"
                            Background="#EEF3FF"
                            CornerRadius="10">
                        <TextBlock Text="{Binding Accounts.Count, StringFormat={}{0} conta(s)}"
                                   FontWeight="SemiBold"/>
                    </Border>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          Margin="0,14,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Accounts}"
                          SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                          Style="{StaticResource ModernDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ModernDataGridCellStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Alias"
                                            Binding="{Binding DisplayName}"
                                            Width="200"/>
                        <DataGridTextColumn Header="Executável"
                                            Binding="{Binding ExecutablePath}"
                                            Width="*"/>
                        <DataGridTextColumn Header="Criado em"
                                            Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}"
                                            Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="5"
                Margin="0,16,0,0"
                Padding="12"
                Background="#11000000"
                CornerRadius="8">
            <TextBlock Text="{Binding Status}"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>

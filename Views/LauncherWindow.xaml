<Window x:Class="RoLauncher.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RoLauncher.ViewModels"
        Title="Launcher de Contas"
        Width="1180"
        Height="760"
        MinWidth="1020"
        MinHeight="680"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Launcher de contas"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}" />
            <TextBlock Margin="0,6,0,0"
                       Text="Restaura os tokens da conta selecionada, abre a instância correspondente e registra o último acesso."
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="Marcar todas"
                    Command="{Binding SelectAllCommand}" />
            <Button Content="Limpar seleção"
                    Command="{Binding ClearSelectionCommand}" />
            <Button Content="Abrir selecionadas"
                    Command="{Binding OpenSelectedCommand}" />
            <Button Content="Abrir todas"
                    Command="{Binding OpenAllCommand}" />
        </StackPanel>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <ListBox ItemsSource="{Binding Accounts}"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LauncherAccountItemViewModel}">
                            <Border Margin="4"
                                    Padding="12"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              VerticalAlignment="Top"
                                              Margin="0,4,0,0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Code}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding InstanceFolderPath}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding LastLaunchText, StringFormat='Última abertura: {0}'}"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Padding="10,6"
                                            Background="#EEF2FF"
                                            CornerRadius="999">
                                        <TextBlock Text="{Binding Status}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Fluxo da abertura"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" />

                    <TextBlock Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Text="1. Restaura os arquivos definidos em TokenRules para a pasta AppData LocalLow\XD\PC.&#10;2. Abre o executável da instância da conta.&#10;3. Aguarda a inicialização básica do processo.&#10;4. Atualiza o último horário de abertura no settings.json." />

                    <Separator Margin="0,16,0,16" />

                    <TextBlock Text="Dica"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="Se a restauração falhar, revise TokenRules no settings.json e confirme se AppData LocalLow\XD\PC está correto." />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="6"
                Padding="12"
                Background="#EEF2FF"
                BorderBrush="#C7D2FE"
                BorderThickness="1"
                CornerRadius="10">
            <TextBlock Text="{Binding Status}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>

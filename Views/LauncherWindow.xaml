<Window x:Class="RoLauncher.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abrir Contas"
        Width="1100"
        Height="700"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#14000000">
        <Border Width="980"
                Padding="24"
                Background="White"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Título -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Abrir Contas"
                               FontSize="26"
                               FontWeight="Bold"/>

                    <TextBlock Text="Selecione as contas que deseja abrir."
                               Margin="0,6,0,0"
                               Opacity="0.75"/>
                </StackPanel>

                <!-- Botões -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                    <Button Width="140"
                            Height="42"
                            Content="Marcar todas"
                            Command="{Binding SelectAllCommand}" />

                    <Button Width="140"
                            Height="42"
                            Margin="12,0,0,0"
                            Content="Limpar seleção"
                            Command="{Binding ClearSelectionCommand}" />

                    <Button Width="170"
                            Height="42"
                            Margin="12,0,0,0"
                            Content="Abrir selecionadas"
                            Command="{Binding OpenSelectedCommand}" />

                    <Button Width="120"
                            Height="42"
                            Margin="12,0,0,0"
                            Content="Abrir todas"
                            Command="{Binding OpenAllCommand}" />
                </StackPanel>

                <!-- Conteúdo -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lista de contas -->
                    <ListBox Grid.Column="0"
                             ItemsSource="{Binding Accounts}"
                             BorderThickness="1"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8"
                                        Padding="12"
                                        BorderBrush="#E4E4E4"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  Margin="0,4,0,0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"/>

                                            <TextBlock Text="{Binding Code}"
                                                       Margin="0,4,0,0"
                                                       Opacity="0.85"/>

                                            <TextBlock Text="{Binding InstanceFolderPath}"
                                                       Margin="0,4,0,0"
                                                       Opacity="0.70"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="{Binding LastLaunchText, StringFormat=Última abertura: {0}}"
                                                       Margin="0,6,0,0"
                                                       FontSize="12"
                                                       Opacity="0.60"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Padding="8"
                                                Background="#F3F3F3"
                                                CornerRadius="8"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Painel lateral -->
                    <Border Grid.Column="2"
                            Padding="16"
                            Background="#FAFAFA"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Fluxo da abertura"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock Margin="0,10,0,0"
                                       TextWrapping="Wrap"
                                       Text="1. Restaura os tokens da conta selecionada.&#10;2. Renomeia para o padrão do jogo.&#10;3. Abre a instância correspondente.&#10;4. Repete para a próxima conta." />

                            <Separator Margin="0,16,0,16"/>

                            <TextBlock Text="Status geral"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding Status}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>